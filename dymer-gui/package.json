    "@ng-matero/extensions-date-fns-adapter": "^20.0.0",
    "@ngneat/overview": "6.1.1",
    "@ngx-formly/core": "^7.0.0",
    "@ngx-formly/material": "^7.0.0",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^16.0.0",
    "@ngxpert/hot-toast": "5.1.1",
